# Disable directory browsing
Options -Indexes

# Prevent viewing of .htaccess file
<Files .htaccess>
    Order allow,deny
    Deny from all
</Files>

# Prevent viewing of sensitive files
<FilesMatch "^(package|package-lock|vite\.config|ai\.txt|README\.md)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to hidden files and folders (e.g., .git)
RewriteRule "(^|/)\." - [F]

# Restrict HTTP methods to GET, POST, and HEAD
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_METHOD} !^(GET|POST|HEAD) [NC]
    RewriteRule .* - [F]
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # SPA Routing
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
